{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "bluppi (debug)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": [
        "--dart-define=ENV=debug",
        "--dart-define=GRPC_SERVER_ADDRESS=0.0.0.0"
      ]
    },
    {
      "name": "bluppi (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": [
        "--dart-define=ENV=profile",
        "--dart-define=API_BASE_URL=https://profile.api.example.com"
      ]
    },
    {
      "name": "bluppi (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": [
        "--dart-define=ENV=prod",
        "--dart-define=API_BASE_URL=https://api.example.com"
      ]
    }
  ]
}
